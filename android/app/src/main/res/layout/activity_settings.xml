<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="48dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="#64FFDA"
        android:textSize="36sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="浏览器标识 (User-Agent)"
        android:textColor="#64FFDA"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="如遇闪退请切换为兼容或默认模式"
        android:textColor="#8892B0"
        android:textSize="13sp" />

    <Spinner
        android:id="@+id/uaSpinner"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:background="#2D2D3E"
        android:padding="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Server URL"
        android:textColor="#8892B0"
        android:textSize="16sp" />

    <EditText
        android:id="@+id/urlInput"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:background="#2D2D3E"
        android:hint="http://192.168.1.100:3000"
        android:inputType="textUri"
        android:padding="16dp"
        android:textColor="#FFFFFF"
        android:textColorHint="#666680"
        android:textSize="18sp" />

    <Button
        android:id="@+id/connectButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:background="#64FFDA"
        android:text="@string/connect"
        android:textColor="#1A1A2E"
        android:textSize="18sp"
        android:textStyle="bold" />

</LinearLayout>
